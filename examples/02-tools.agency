export def greet(name: string): string {
  """
  Greet the user with a message. This tool is used to demonstrate how to create and use custom tools in an agent.
  """
  return "Hi from Etsy! ${name}"
}

node main() {
  const result = llm("Use your `greet` tool to greet Adit", {
    tools: [greet]
  })
  print(result)
}
