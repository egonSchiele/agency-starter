def getCapital(country: string): string {
  """
  Get the capital of a country. Currently only supports India.

  @param country - The name of the country to get the capital for.
  """
  if (country == "India") {
    return "New Delhi"
  } else {
    return "Unknown"
  }
}

node main() {
  const result = llm(
    "Use your `getCapital` tool to find the capital of India",
    {
    tools: [getCapital]
  },
  )
  print(result)
}
